
# eza instead of ls
alias ls="eza -l --icons"
alias la="eza -la --icons"
alias l="eza --icons"
alias ll="eza -l --icons"

# directory navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias -- -="cd -"
alias md="mkdir -p"
alias rd="rmdir"

# directory stack
alias d="dirs -v"
for index ({1..9}) alias "$index"="cd -$index"; unset index

# safety nets
alias cp="cp -i"
alias mv="mv -i"

# color
alias grep="grep --color=auto"
alias fgrep="fgrep --color=auto"
alias egrep="egrep --color=auto"
alias diff="diff --color=auto"
alias ip="ip --color=auto"

# misc
alias open="xdg-open 2>/dev/null"

# wget: skip cert check (self-signed) and strip query params from filename
alias wget="wget --no-check-certificate --content-disposition"

# completion caching so tab-complete doesn't hang on first use
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.cache/zsh-completions

# zoxide as cd
eval "$(zoxide init zsh --cmd cd)"

# fzf
source <(fzf --zsh 2>/dev/null || true)

PROMPT=$'%F{green}%n@%m%f %F{blue}%(4~|%-1~/.../%2~|%3~)%f\n%F{red}$%f '
