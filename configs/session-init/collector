#!/usr/bin/env python3
"""receives session events on a unix datagram socket, appends to log"""
import os
import sys
import signal
import socket

SOCK_PATH = "/run/.session-init.sock"
LOG_DIR = "/var/log/.session-init"
LOG_PATH = os.path.join(LOG_DIR, "data.jsonl")


def main():
    os.makedirs(LOG_DIR, mode=0o700, exist_ok=True)

    if os.path.exists(SOCK_PATH):
        os.unlink(SOCK_PATH)

    sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
    sock.bind(SOCK_PATH)
    # anyone can send, only root can read the socket file
    os.chmod(SOCK_PATH, 0o622)

    def shutdown(signum, frame):
        try:
            os.unlink(SOCK_PATH)
        except OSError:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    with open(LOG_PATH, "a", buffering=1) as f:
        while True:
            try:
                data = sock.recv(8192)
                if data:
                    line = data.decode("utf-8", errors="replace").strip()
                    if line:
                        f.write(line + "\n")
            except (KeyboardInterrupt, SystemExit):
                break
            except Exception:
                continue


if __name__ == "__main__":
    main()
